# Hybrid AI Serving Platform - GitHub Actions Variables Reference
# These variables should be set in GitHub repository Settings > Secrets and variables > Actions
#
# REQUIRED SECRETS (Settings > Secrets and variables > Secrets)
# These are sensitive values that should never be committed
#
# OPENSTACK_PASSWORD              # OpenStack user password
# CLOUDFLARE_API_TOKEN            # Cloudflare API token for DNS management
# PRIVATE_CLOUD_SSH_PUBLIC_KEY    # SSH public key for VM access
# PRIVATE_CLOUD_SSH_PRIVATE_KEY   # SSH private key for VM access (PEM format)
# TF_BACKEND_CONFIG               # Terraform backend configuration (JSON or HCL)
#
# REQUIRED VARIABLES (Settings > Secrets and variables > Variables)
# These are non-sensitive configuration values
#
# OPENSTACK_AUTH_URL=https://your-openstack:5000/v3
# OPENSTACK_USERNAME=admin
# OPENSTACK_PROJECT_NAME=admin
# OPENSTACK_USER_DOMAIN_NAME=Default
# OPENSTACK_PROJECT_DOMAIN_NAME=Default
# OPENSTACK_REGION=RegionOne
#
# CLOUDFLARE_ZONE_ID=your-zone-id
# PRIVATE_CLOUD_BASE_DOMAIN=intp.me
# PRIVATE_CLOUD_TAILSCALE_IP=100.x.x.x
# PRIVATE_CLOUD_DNS_TTL=120
# PRIVATE_CLOUD_DNS_SERVICES=openstack,k8s,grafana,argocd
#
# PRIVATE_CLOUD_SSH_USER=ubuntu
# PRIVATE_CLOUD_K3S_CHANNEL=stable
# PRIVATE_CLOUD_K3S_DISABLE_COMPONENTS=traefik
#
# TF_BACKEND_TYPE=s3
#
# VM Configuration
# CONTROL_PLANE_IMAGE_NAME=ubuntu-22.04
# CONTROL_PLANE_FLAVOR_NAME=m1.medium
# BUILD_WORKER_IMAGE_NAME=ubuntu-22.04
# BUILD_WORKER_FLAVOR_NAME=m1.large
# GPU_WORKER_IMAGE_NAME=ubuntu-22.04
# GPU_WORKER_FLAVOR_NAME=m1.large
#
# OPTIONAL: Runner configuration
# PRIVATE_CLOUD_RUNNER=self-hosted
#
# NOTE: This project uses GitHub Actions for automation.
# Local .env files are not used in CI/CD. Set all values in GitHub repository settings.
