# Hybrid AI Serving Platform local secrets.
# Copy to .env.secret only for local `ha` CLI runs.
# GitHub Actions does not read this file. Put CI/CD values in repository
# Settings > Secrets and variables > Actions.
# Do not commit .env.secret.

# Local provider normally needs no secrets here.

# Existing OpenStack provider credentials, only needed when HA_PROVIDER=openstack.
# These are local `ha` credentials, not GitHub Actions credentials.
# export OS_USERNAME=""
# export OS_PASSWORD=""

# Existing Kubernetes access, only needed when applying to an already-created cluster.
# export KUBECONFIG="/path/to/private-cluster-kubeconfig"
# export PRIVATE_KUBECONFIG_B64="base64-encoded-kubeconfig"

# Cloudflare DNS automation and Caddy DNS-01 certificate issuance.
# Required permissions: Zone:Read and DNS:Edit scoped to the target zone.
# export CLOUDFLARE_API_TOKEN=""

# Optional Terraform remote state backend for local shared apply/destroy workflows.
# export TF_BACKEND_CONFIG='bucket="REPLACE"
# key="private-cloud/terraform.tfstate"
# region="REPLACE"
# endpoint="REPLACE"
# access_key="REPLACE"
# secret_key="REPLACE"
# skip_credentials_validation=true
# skip_region_validation=true
# skip_metadata_api_check=true
# force_path_style=true'
